      }
    },
    "invalid-units": {
      "intent": "Unit references a missing analyte key and should fail domain unit linkage checks.",
      "workbook": "tests/fixtures/workbooks/invalid-units/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": [
          "unknown-analyte-key",
          "missing-analyte-units"
        ]
      }
    },
    "malformed-workbook": {
      "intent": "Non-zip payload with .xlsx extension should fail workbook loading.",
      "workbook": "tests/fixtures/workbooks/malformed-workbook/not-a-workbook.xlsx",
      "expected": {
        "import": "failure",
        "error_type": "invalid-workbook",
        "diagnostics": [
          {
            "rule_id": "invalid-workbook",
            "sheet": "(workbook)"
          }
        ]
      }
    },
    "variant-v1-flat": {
      "intent": "Legacy single-sheet layout should import successfully.",
      "workbook": "tests/fixtures/workbooks/variant-v1-flat/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": []
