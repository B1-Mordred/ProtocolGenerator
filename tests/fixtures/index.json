    "single-assay": {
      "intent": "One assay with multiple analytes and one unit per analyte.",
      "workbook": "tests/fixtures/workbooks/single-assay/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": []
      }
    },
    "multi-assay": {
      "intent": "Two assays to exercise per-assay processing grouping behavior.",
      "workbook": "tests/fixtures/workbooks/multi-assay/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": []
      }
    },
    "multi-analyte": {
      "intent": "Single assay with three analytes and heterogeneous units.",
      "workbook": "tests/fixtures/workbooks/multi-analyte/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": []
      }
    },
    "alias-driven-mapping": {
      "intent": "Alias-style unit tokens exercise importer normalization and multi-unit splitting.",
      "workbook": "tests/fixtures/workbooks/alias-driven-mapping/workbook.json",
      "expected": {
        "import": "success",
        "error_codes": [],
        "normalized_units": [
          "mg/dL",
          "\u00b5g/mL"
        ]
      }
    },
    "invalid-cross-file-mapping": {
      "intent": "Analyte references a missing assay key and should fail domain linkage checks.",
      "workbook": "tests/fixtures/workbooks/invalid-cross-file-mapping/workbook.json",
